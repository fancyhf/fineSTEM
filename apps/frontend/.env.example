VITE_API_URL=

# ZeroClaw Gateway（真实 AI 运行时，详见 docs/技术与架构/ZeroClaw_技术知识库_v1.0.0.md）
VITE_ZC_URL=http://127.0.0.1:42617
VITE_ZC_TOKEN=请在配对后填入 zc_<64位 hex>
VITE_ZC_AGENT=assistant

# 可选：前端站点标题
VITE_APP_NAME=fineSTEM
# fineSTEM Backend
APP_NAME=fineSTEM API
APP_VERSION=0.1.0
DEBUG=True

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5273","http://localhost:4500"]

# ZeroClaw Gateway (required for real AI)
ZEROCLAW_GATEWAY_URL=
ZEROCLAW_FALLBACK_GATEWAY_URL=
ZEROCLAW_API_KEY=
ZEROCLAW_DEFAULT_MODEL=glm-5-turbo
ZEROCLAW_FALLBACK_MODEL=qwen-plus
ZEROCLAW_ENABLE_MOCK_FALLBACK=False
ZEROCLAW_TIMEOUT_SECONDS=30
glm_key=

# Database
DATABASE_URL=sqlite:///D:/data/finestem/finestem.db

# Storage
STORAGE_BASE_PATH=D:/data/finestem
STORAGE_UPLOAD_DIR=uploads
STORAGE_PACKAGES_DIR=packages
STORAGE_EXPORTS_DIR=exports
STORAGE_INDEX_FILE=file_index.json

# JWT
# 生产环境必须设置强随机密钥（示例生成：python -c "import secrets; print(secrets.token_urlsafe(48))"）
# 开发环境未配置时会回退到临时开发密钥，仅用于本地调试
SECRET_KEY=replace-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

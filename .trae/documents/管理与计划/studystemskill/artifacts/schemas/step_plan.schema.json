{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "track_selected",
    "milestones"
  ],
  "properties": {
    "track_selected": {
      "type": "string"
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "demo",
          "steps"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "demo": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "step_id",
                "goal",
                "change_budget",
                "run",
                "check",
                "rollback",
                "teach_point"
              ],
              "properties": {
                "step_id": {
                  "type": "string"
                },
                "goal": {
                  "type": "string"
                },
                "change_budget": {
                  "type": "object",
                  "required": [
                    "max_lines",
                    "max_files"
                  ],
                  "properties": {
                    "max_lines": {
                      "type": "integer",
                      "maximum": 30
                    },
                    "max_files": {
                      "type": "integer",
                      "maximum": 2
                    }
                  }
                },
                "files": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "run": {
                  "type": "string"
                },
                "check": {
                  "type": "array",
                  "minItems": 2,
                  "items": {
                    "type": "string"
                  }
                },
                "rollback": {
                  "type": "string"
                },
                "teach_point": {
                  "type": "string"
                },
                "quiz": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
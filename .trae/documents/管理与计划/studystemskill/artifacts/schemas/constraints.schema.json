{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "time_budget",
    "must_have",
    "wont_do",
    "resource_limits"
  ],
  "properties": {
    "time_budget": {
      "type": "string",
      "enum": [
        "2h",
        "6h",
        "12h"
      ]
    },
    "difficulty_level": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "must_have": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "nice_to_have": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "wont_do": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "resource_limits": {
      "type": "object",
      "required": [
        "devices",
        "data"
      ],
      "properties": {
        "devices": {
          "type": "object",
          "properties": {
            "has_pico_board": {
              "type": "boolean"
            },
            "has_sensors": {
              "type": "boolean"
            }
          }
        },
        "data": {
          "type": "object",
          "properties": {
            "can_use_internet": {
              "type": "boolean"
            },
            "dataset_ready": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "safety_rules": {
      "type": "object"
    }
  }
}
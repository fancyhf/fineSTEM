{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "track_selected",
    "design_variant"
  ],
  "properties": {
    "track_selected": {
      "type": "string"
    },
    "design_variant": {
      "type": "string",
      "enum": [
        "web",
        "hardware",
        "kaggle",
        "course"
      ]
    },
    "web": {
      "type": [
        "object",
        "null"
      ]
    },
    "hardware": {
      "type": [
        "object",
        "null"
      ]
    },
    "kaggle": {
      "type": [
        "object",
        "null"
      ]
    },
    "course": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "track_selected",
    "acceptance_results",
    "showcase_script",
    "reflection"
  ],
  "properties": {
    "track_selected": {
      "type": "string"
    },
    "acceptance_results": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "test",
          "result"
        ],
        "properties": {
          "test": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "metrics_or_scores": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "showcase_script": {
      "type": "object"
    },
    "reflection": {
      "type": "object",
      "required": [
        "learned",
        "next_steps"
      ],
      "properties": {
        "learned": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          }
        },
        "hardest_part": {
          "type": "string"
        },
        "next_steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
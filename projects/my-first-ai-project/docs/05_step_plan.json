          "name": "配置开发环境",
          "run": "安装Flask: pip install Flask",
          "check": "能成功导入Flask库",
          "rollback": "卸载重装: pip uninstall Flask && pip install Flask",
          "time_estimate": "15min"
        },
        {
          "id": "step_2",
          "name": "运行空应用",
          "run": "cd src && python app.py",
          "check": "能访问 http://localhost:5000 看到页面",
          "rollback": "检查代码语法和端口占用",
          "time_estimate": "15min"
        },
        {
          "id": "step_3",
          "name": "测试基础功能",
          "run": "测试卡片展示、搜索、分类筛选",
          "check": "基础功能正常工作",
          "rollback": "检查路由和模板路径",
          "time_estimate": "30min"
        }
      ]
    },
    {

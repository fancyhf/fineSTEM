{
  "design_variant": "web_streamlit",
  "ui_design": {
    "style": "科技感 + 简约",
    "color_scheme": {
      "primary": "#4CAF50",
      "secondary": "#2196F3",
      "background": "#0e1117",
      "text": "#ffffff"
    },
    "elements": [
      "文件上传区",
      "词云展示区",
      "统计面板",
      "操作按钮",
      "导出按钮"
    ],
    "layout": "上下分区 + 左右分栏"
  },
  "components": [
    {
      "name": "FileUploader",
      "props": ["file_types", "max_size"],
      "description": "上传字幕文件"
    },
    {
      "name": "WordCloudDisplay",
      "props": ["word_freq", "width", "height"],
      "description": "展示词云图"
    },
    {
      "name": "StatsPanel",
      "props": ["total_words", "unique_words", "top_keywords"],
      "description": "数据统计面板"
    },
    {
      "name": "AISummary",
      "props": ["summary_text", "loading"],
      "description": "AI 智能总结"
    },
    {
      "name": "ExportButton",
      "props": ["format", "filename"],
      "description": "导出报告"
    }
  ],
  "data_flow": {
    "input": "user_upload (SRT/TXT file)",
    "process": "parse_subtitle → tokenize_chinese → count_frequency → generate_visualization",
    "output": "wordcloud_image + stats_data + summary_text"
  },
  "acceptance_tests": [
    {
      "given": "用户上传 SRT 字幕文件",
      "when": "点击分析按钮",
      "then": "显示词云图、统计面板和 AI 总结"
    },
    {
      "given": "用户上传 TXT 文本文件",
      "when": "自动触发分析",
      "then": "同样生成完整报告"
    },
    {
      "given": "用户点击导出",
      "when": "选择 PNG 格式",
      "then": "下载词云图片"
    }
  ]
}

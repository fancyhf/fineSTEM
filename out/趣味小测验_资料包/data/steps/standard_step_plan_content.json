"{\n  \"milestones\": [\n    {\n      \"id\": \"M1\",\n      \"name\": \"HTML页面骨架\",\n      \"steps\": [\n        {\"step\": 1, \"action\": \"创建index.html，包含标题区、题目区、选项区、结果区\", \"check\": \"浏览器打开能看到完整结构布局\"},\n        {\"step\": 2, \"action\": \"编写CSS样式：渐变色背景、卡片样式、按钮样式\", \"check\": \"页面美观，卡片居中\"}\n      ]\n    },\n    {\n      \"id\": \"M2\",\n      \"name\": \"题库与交互逻辑\",\n      \"steps\": [\n        {\"step\": 3, \"action\": \"定义题库数组（6道科学题），每道含题目、4个选项、正确答案索引和解析\", \"check\": \"数组结构正确，包含所有题目\"},\n        {\"step\": 4, \"action\": \"实现随机出题逻辑（sort随机打乱）\", \"check\": \"每次刷新题目顺序不同\"},\n        {\"step\": 5, \"action\": \"实现选项点击交互：判断对错、高亮显示、展示解析\", \"check\": \"点击正确变绿，点击错误变红且正确选项变绿\"}\n      ]\n    },\n    {\n      \"id\": \"M3\",\n      \"name\": \"计分与结果展示\",\n      \"steps\": [\n        {\"step\": 6, \"action\": \"实现自动计分（答对+1）\", \"check\": \"分数正确累加\"},\n        {\"step\": 7, \"action\": \"实现结果页面：显示总分、每题对错列表、鼓励评语\", \"check\": \"结果页面展示完整\"},\n        {\"step\": 8, \"action\": \"实现「再玩一次」功能，重置所有状态\", \"check\": \"点击后重新开始，题库重新打乱\"}\n      ]\n    }\n  ],\n  \"total_steps\": 8\n}"
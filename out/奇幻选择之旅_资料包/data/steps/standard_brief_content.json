"{\n  \"project_name\": \"奇幻选择之旅\",\n  \"project_id\": \"b686df08-6655-4edb-a3a5-955f3244abe1\",\n  \"one_liner\": \"一个让读者通过做选择来推进剧情的互动故事网页\",\n  \"target_audience\": \"初中生（同龄人）\",\n  \"skill_level\": \"零基础\",\n  \"time_budget\": \"6小时\",\n  \"tech_stack\": \"HTML + CSS + JavaScript（纯前端）\",\n  \"problem_statement\": \"很多初中生喜欢看故事、玩游戏，但很少有适合零基础学生自己动手做的互动叙事作品。奇幻选择之旅让零基础学生也能从0开始，用最基础的网页技术做出一个属于自己的互动故事。\",\n  \"success_criteria\": [\n    {\n      \"id\": \"sc_01\",\n      \"description\": \"能顺畅展示一个完整故事，读者从开头读到结局，中间分支都能走通\",\n      \"priority\": \"must\"\n    },\n    {\n      \"id\": \"sc_02\",\n      \"description\": \"至少有3个关键选择点，每个选择都有不同剧情走向\",\n      \"priority\": \"must\"\n    },\n    {\n      \"id\": \"sc_03\",\n      \"description\": \"视觉风格统一好看，配色、字体、按钮整体协调\",\n      \"priority\": \"nice_to_have\"\n    }\n  ],\n  \"risks\": [\n    {\n      \"id\": \"risk_01\",\n      \"description\": \"剧情卡壳写不出故事\",\n      \"impact\": \"中\",\n      \"fallback\": \"我提供故事模板和主线框架，学生直接套用填空\"\n    },\n    {\n      \"id\": \"risk_02\",\n      \"description\": \"零基础第一次写代码，进度慢\",\n      \"impact\": \"高\",\n      \"fallback\": \"我每一步都给出完整代码示例，引导学生逐行理解\"\n    },\n    {\n      \"id\": \"risk_03\",\n      \"description\": \"6小时内做不完完整功能\",\n      \"impact\": \"中\",\n      \"fallback\": \"按优先级砍功能：保留核心故事流程，砍掉动画效果和多结局\"\n    }\n  ],\n  \"milestones\": [\n    {\n      \"id\": \"ms_01\",\n      \"name\": \"故事创作\",\n      \"estimated_hours\": 1,\n      \"description\": \"确定故事主题、角色、3个选择点及分支结局\"\n    },\n    {\n      \"id\": \"ms_02\",\n      \"name\": \"页面骨架\",\n      \"estimated_hours\": 1.5,\n      \"description\": \"用HTML搭建故事展示页、选择按钮页、结局页的基础结构\"\n    },\n    {\n      \"id\": \"ms_03\",\n      \"name\": \"故事逻辑\",\n      \"estimated_hours\": 2,\n      \"description\": \"用JavaScript实现选择跳转、剧情推进、结局判定\"\n    },\n    {\n      \"id\": \"ms_04\",\n      \"name\": \"视觉美化\",\n      \"estimated_hours\": 1,\n      \"description\": \"加配色、字体、背景、按钮样式，让页面好看\"\n    },\n    {\n      \"id\": \"ms_05\",\n      \"name\": \"测试与展示\",\n      \"estimated_hours\": 0.5,\n      \"description\": \"完整走一遍故事流程，修复bug\"\n    }\n  ],\n  \"created_at\": \"2026-06-30T13:20:00.000Z\",\n  \"updated_at\": \"2026-06-30T13:33:00.000Z\"\n}\n"
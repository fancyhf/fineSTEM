"{\n  \"time_budget\": \"6h\",\n  \"must_have\": [\n    \"故事页面展示 —— 显示当前剧情文本，读者可阅读故事内容\",\n    \"选择按钮 —— 每个关键节点提供选项按钮，读者点击进行选择\",\n    \"分支剧情 —— 根据读者选择跳转到不同剧情段落，形成分支\"\n  ],\n  \"must_have_max\": 3,\n  \"nice_to_have\": [],\n  \"wont_do\": [\n    \"用户登录系统 —— 不需要注册账号，打开即玩\",\n    \"多语言翻译 —— 专注中文故事，不做国际化\",\n    \"音效与背景音乐 —— 纯文字+视觉互动体验\",\n    \"数据统计面板 —— 不做播放量/点击量等后台分析\"\n  ],\n  \"wont_do_min\": 4,\n  \"max_pages\": 1,\n  \"max_components\": 6,\n  \"tech_limitations\": [\n    \"纯前端项目，无需后端\",\n    \"使用 HTML + CSS + JavaScript，零框架\",\n    \"所有故事数据用 JavaScript 对象管理\"\n  ]\n}\n"
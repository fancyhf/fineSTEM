# =============================================================================
# fineSTEM monorepo environment template
# Copy to `.env` at repo root if you run tools/scripts from root.
# App-specific env files can still live in:
# - apps/backend/.env
# - apps/frontend/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Common
# -----------------------------------------------------------------------------
APP_NAME=fineSTEM API
APP_VERSION=0.1.0
DEBUG=True

# -----------------------------------------------------------------------------
# Backend API / Auth
# -----------------------------------------------------------------------------
API_V1_STR=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
DATABASE_URL=sqlite:///D:/data/finestem/finestem.db
SECRET_KEY=replace-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# Backend storage
# -----------------------------------------------------------------------------
STORAGE_BASE_PATH=D:/data/finestem
STORAGE_UPLOAD_DIR=uploads
STORAGE_PACKAGES_DIR=packages
STORAGE_EXPORTS_DIR=exports
STORAGE_INDEX_FILE=file_index.json

# -----------------------------------------------------------------------------
# Agent / provider runtime
# 2026-07-19 起 AI 调用走真实 ZeroClaw v0.8.3 网关（H:\dev-env\zeroclaw）
# DeepSeek API key 写在 ZeroClaw config.toml 的 [providers.models.deepseek.default] 里。
# 后端 ZEROCLAW_* 字段仅用于向后兼容遗留 tool registry；新接入请直接读 ZC ws/webhook。
# 详见 docs/技术与架构/ZeroClaw_技术知识库_v1.0.0.md
# -----------------------------------------------------------------------------
ZEROCLAW_GATEWAY_URL=http://127.0.0.1:42617
ZEROCLAW_FALLBACK_GATEWAY_URL=
ZEROCLAW_API_KEY=
ZEROCLAW_DEFAULT_MODEL=deepseek-chat
ZEROCLAW_FALLBACK_MODEL=qwen-plus
ZEROCLAW_LOCAL_SAFE_MODEL=local-safe
ZEROCLAW_ENABLE_MOCK_FALLBACK=False
ZEROCLAW_TIMEOUT_SECONDS=60

AGENT_SKILL_TIMEOUT_MS=15000
AGENT_ALLOW_NETWORK_SKILL=False
AGENT_ALLOWED_FS_PATHS=[]
AGENT_METRICS_STORAGE_PATH=runtime/agent_metrics.json
AGENT_FEATURE_FLAGS_PATH=runtime/feature_flags.json

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
FF_AGENT_STREAM_ENABLED=True
FF_AGENT_STREAM_ROLLOUT_PERCENT=100
FF_AGENT_WS_ENABLED=True
FF_AGENT_WS_ROLLOUT_PERCENT=100
FF_SKILL_SANDBOX_ENABLED=True
FF_SKILL_SANDBOX_ROLLOUT_PERCENT=100
FF_PROVIDER_FALLBACK_ENABLED=True
FF_PROVIDER_FALLBACK_ROLLOUT_PERCENT=100
FF_METRICS_PERSISTENCE_ENABLED=True

# -----------------------------------------------------------------------------
# Frontend (Vite)
# VITE_ZC_* 是前端直连 ZeroClaw 网关（ws://127.0.0.1:42617/ws/chat）的 Bearer Token
# Token 由 `POST /pair` 派发；详见 docs/技术与架构/ZeroClaw_技术知识库_v1.0.0.md
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=fineSTEM
VITE_ZC_URL=http://127.0.0.1:42617
VITE_ZC_TOKEN=请在配对后填入 zc_<64位 hex>
VITE_ZC_AGENT=assistant
